# ──────────────────────────────────────────────
# Service: nginx
# Reverse-engineered from: nginx:latest
# ──────────────────────────────────────────────
FROM nginx:latest
 
# Default config serves from /usr/share/nginx/html on port 80
# Replace with your own nginx.conf if needed:
# COPY nginx.conf /etc/nginx/nginx.conf
 
# Optional: copy static content
# COPY ./html/ /usr/share/nginx/html/
 
EXPOSE 80
 
CMD ["nginx", "-g", "daemon off;"]
