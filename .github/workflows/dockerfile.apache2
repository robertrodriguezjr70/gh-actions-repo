# ──────────────────────────────────────────────
# Service: apache
# Reverse-engineered from: httpd:latest
# ──────────────────────────────────────────────
FROM httpd:latest

# Default Apache config is at /usr/local/apache2/conf/httpd.conf
# Static content is served from /usr/local/apache2/htdocs/

# Copy local html content into the image (replaces the volume mount)
COPY ./html/ /usr/local/apache2/htdocs/

EXPOSE 80

CMD ["httpd-foreground"]
